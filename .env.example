# ==========================================================
# HOME CHEF - VARIABLES DE ENTORNO DEL FRONTEND
# ==========================================================
#
# Este archivo es SOLO un ejemplo.
# No se usa directamente para correr el proyecto.
#
# Cada desarrollador debe copiar este archivo y crear uno de estos:
#
#   .env.development   → para trabajar en local
#   .env.production    → para producción
#   .env               → opcional, si quiere usar una sola configuración
#
# Ejemplo:
#   cp .env.example .env.development
#
# IMPORTANTE:
# En proyectos con Vite, todas las variables deben empezar con VITE_.
# Además, todo lo que empiece con VITE_ puede ser visible desde el navegador.
# Por eso NO se deben poner claves privadas aquí.


# ==========================================================
# URL DEL BACKEND DJANGO
# ==========================================================
#
# Esta variable le dice al frontend a qué backend debe conectarse.
#
# Para desarrollo local, usar:
#   http://localhost:8000
#
# Para producción, usar:
#   https://proyecto.leonardoserrate.xyz
#
# Ejemplo local:
#   VITE_API_URL=http://localhost:8000
#
# Ejemplo producción:
#   VITE_API_URL=https://proyecto.leonardoserrate.xyz/api/v1

VITE_API_URL=http://localhost:8000/api/v1
VITE_API_BASE_URL=http://localhost:8000
VITE_ORDER_COINGATE_SUCCESS_REDIRECT_TO=https://proyecto.leonardoserrate.xyz/client/payments/bitcoin-coingate/return?payment=coingate_success
VITE_ORDER_COINGATE_CANCEL_REDIRECT_TO=https://proyecto.leonardoserrate.xyz/client/payments/bitcoin-coingate/return?payment=coingate_cancel
VITE_ORDER_STRIPE_SUCCESS_REDIRECT_TO=https://proyecto.leonardoserrate.xyz/client/payments/stripe/return?payment=stripe_success
VITE_ORDER_STRIPE_CANCEL_REDIRECT_TO=https://proyecto.leonardoserrate.xyz/client/payments/stripe/return?payment=stripe_cancel


# ==========================================================
# NOMBRE DE LA APLICACIÓN
# ==========================================================
#
# Nombre que puede mostrarse en títulos, navbar, metadata, etc.

VITE_APP_NAME=HomeChef


# ==========================================================
# SUPABASE - URL DEL PROYECTO
# ==========================================================
#
# URL pública del proyecto de Supabase.
#
# Se obtiene en:
#   Supabase Dashboard → Project Settings → API → Project URL
#
# Esta URL puede estar en el frontend porque no es una clave secreta.

VITE_SUPABASE_URL=https://pimmweiqnensrevyzvqn.supabase.co


# ==========================================================
# SUPABASE - ANON PUBLIC KEY
# ==========================================================
#
# Esta es la clave pública "anon" de Supabase.
#
# Se obtiene en:
#   Supabase Dashboard → Project Settings → API → anon public key
#
# Esta clave puede usarse en el frontend.
#
# IMPORTANTE:
# NO usar aquí la "service_role key".
# La service_role key es privada y solo debe estar en el backend o en Render,
# nunca en el frontend ni en GitHub.

VITE_SUPABASE_ANON_KEY=coloca_aqui_tu_supabase_anon_key
